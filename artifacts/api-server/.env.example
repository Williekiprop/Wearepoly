# Copy this file to .env and fill in your values
# Get these from the Replit Secrets panel (lock icon in sidebar)

PORT=8080

POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_passphrase_here
POLYMARKET_WALLET_KEY=your_wallet_private_key_here

# Optional: set a proxy URL if needed (leave blank when running locally with VPN)
# PROXY_URL=http://user:pass@proxy-host:port
